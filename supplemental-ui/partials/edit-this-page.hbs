{{#if (and page.fileUri (not env.CI))}}
<div class="edit-this-page adt-edit-this-page">
  <a class="adt-edit-this-page-link" href="{{page.fileUri}}"><span class="adt-edit-github-icon" aria-hidden="true">{{> adt-icon-github-inline}}</span> Edit this page</a>
</div>
{{else if (and page.editUrl (or env.FORCE_SHOW_EDIT_PAGE_LINK (not page.origin.private)))}}
<div class="edit-this-page adt-edit-this-page">
  <a class="adt-edit-this-page-link" href="{{page.editUrl}}"><span class="adt-edit-github-icon" aria-hidden="true">{{> adt-icon-github-inline}}</span> Edit this page</a>
</div>
{{/if}}
